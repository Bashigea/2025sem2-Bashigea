#| echo: false
#| message: false
#| warning: false
# Load the Hennepin County SNAP and MFIP dataset
HennepinData <- read_csv("../../../../hennepin-county-data-project-2026-tai/data_private/HennepinCounty_SNAP_MFIP_Estimates_Tract_RevA.csv")
# Average across all months per tract
snap_clean <- HennepinData |>
mutate(
SNAP_people = as.numeric(SNAP_people),
p_125_povertyE = as.numeric(p_125_povertyE)
) |>
filter(!is.na(SNAP_people), !is.na(p_125_povertyE)) |>
group_by(GEOID) |>
summarise(
SNAP_people = mean(SNAP_people, na.rm = TRUE),
p_125_povertyE = mean(p_125_povertyE, na.rm = TRUE)
)
ggplot(snap_clean, aes(x = p_125_povertyE, y = SNAP_people)) +
geom_point(alpha = 0.6, color = "steelblue") +
geom_smooth(method = "lm", se = FALSE, color = "darkred", linetype = "dashed") +
labs(
title = "Poverty vs SNAP Participation by Census Tract",
subtitle = "Each point represents a census tract in Minneapolis",
x = "People at 125% Poverty Level",
y = "SNAP Participants"
) +
theme_minimal()
#| echo: false
#| message: false
#| warning: false
# Filter to 2023-2025 and average per tract
snap_recent <- HennepinData |>
mutate(
SNAP_cases = as.numeric(SNAP_cases),
SNAP_people = as.numeric(SNAP_people),
SNAP_children = as.numeric(SNAP_children),
p_125_povertyE = as.numeric(p_125_povertyE),
GEOID = as.character(GEOID),
NAME = str_replace_all(NAME, ";", ","),
Year = YearMonth %/% 100
) |>
filter(Year %in% c(2023, 2024, 2025)) |>
filter(!is.na(SNAP_cases), !is.na(SNAP_people),
!is.na(SNAP_children), !is.na(p_125_povertyE)) |>
group_by(GEOID, NAME) |>
summarise(
SNAP_cases = mean(SNAP_cases, na.rm = TRUE),
SNAP_people = mean(SNAP_people, na.rm = TRUE),
SNAP_children = mean(SNAP_children, na.rm = TRUE),
p_125_povertyE = mean(p_125_povertyE, na.rm = TRUE),
.groups = "drop"
) |>
mutate(
snap_takeup = pmin(SNAP_cases / ifelse(p_125_povertyE == 0, NA, p_125_povertyE), 1.5),
pov_quartile = ntile(p_125_povertyE, 4),
pov_label = case_when(
pov_quartile == 1 ~ "Q1 Low Poverty",
pov_quartile == 2 ~ "Q2",
pov_quartile == 3 ~ "Q3",
pov_quartile == 4 ~ "Q4 High Poverty"
),
pov_label = factor(pov_label,
levels = c("Q1 Low Poverty", "Q2", "Q3", "Q4 High Poverty"))
)
# Flag underenrolling tracts
lm_model <- lm(SNAP_people ~ p_125_povertyE, data = snap_recent)
snap_recent <- snap_recent |>
mutate(
expected_snap = predict(lm_model, newdata = snap_recent),
enrollment_status = case_when(
SNAP_people < expected_snap ~ "Below Line (Underenrolling)",
TRUE ~ "Above Line (Enrolling as Expected)"
)
)
# Plot faceted by poverty quartile
ggplot(snap_recent, aes(x = p_125_povertyE, y = snap_takeup,
color = enrollment_status)) +
geom_point(alpha = 0.6, size = 2) +
geom_smooth(method = "lm", se = FALSE, color = "darkred", linetype = "dashed") +
scale_color_manual(values = c(
"Below Line (Underenrolling)" = "red",
"Above Line (Enrolling as Expected)" = "steelblue"
)) +
facet_wrap(~ pov_label) +
labs(
title = "SNAP Take-Up Rate by Poverty Quartile (2023-2025)",
subtitle = "Red = underenrolling | Blue = enrolling as expected",
x = "People at 125% Poverty Level",
y = "SNAP Take-Up Rate (cases per poverty population)",
color = "Enrollment Status"
) +
theme_minimal() +
theme(legend.position = "bottom")
