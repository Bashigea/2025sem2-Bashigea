df <- read.csv("C:/Users/IvanL/OneDrive/Documents/Augsburg/DST490Projects/GitProjects/hennepin-county-data-project-2026-tai/data_private/HennepinCounty_SNAP_MFIP_Estimates_Tract_RevA.csv")
